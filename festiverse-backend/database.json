{
  "dev": {
    "driver": "pg",
    "user": "${process.env.SUPABASE_DB_USER}",
    "password": "${process.env.SUPABASE_DB_PASSWORD}",
    "host": "${process.env.SUPABASE_DB_HOST}",
    "port": 5432,
    "database": "${process.env.SUPABASE_DB_NAME}",
